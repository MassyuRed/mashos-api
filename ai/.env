AI_NAME=CocolonAI
APP_NAME=AppTBD
PROJECT_NAME=Cocolon

# EmlisAI limited Composer connection visibility baseline.
# Keep these commented unless the local runtime should actually connect the
# Cocolon internal limited Composer.  Step 1 diagnostics can distinguish
# pre-connection stops from Composer/Gate rejections without changing DB/API
# contracts or user-facing display rules.
# COCOLON_EMLIS_LIMITED_COMPOSER_ENABLED=1
# COCOLON_EMLIS_LIMITED_COMPOSER_ROLLOUT_STAGE=all
# COCOLON_EMLIS_DEFAULT_COMPOSER=limited
