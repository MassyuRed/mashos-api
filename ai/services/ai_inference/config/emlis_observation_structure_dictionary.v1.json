{
  "schema_version": "emlis.observation_structure_dictionary.v1",
  "dictionary_id": "emlis_observation_structure_dictionary",
  "dictionary_version": "emlis.observation_structure_dictionary.action_conversion_unformed_self_insight.2026-05-22",
  "contract_step": "Phase2_Observation_Structure_Dictionary_Schema",
  "base_dictionary": "cocolon_foundation_structure_dictionary",
  "status": "implementation_schema_phase2",
  "purpose": "EmlisAIが入力の束を根拠に、ユーザーの状態を観測するための専用構造辞書。入力語・入力束・関係・内部問い・allowed/forbidden inference・surface policy を持つ。",
  "non_goals": [
    "完成返答文テンプレ集",
    "一般共感文集",
    "人格診断",
    "原因決め打ち",
    "Piece生成辞書",
    "分析レポート辞書"
  ],
  "input_bundle_policy": {
    "required_current_input_fields": [
      "memo",
      "memo_action",
      "emotion_details",
      "category"
    ],
    "normalized_field_mapping": {
      "thought_text": {
        "source_field": "memo",
        "meaning": "自己世界の出来事。内側で起きた解釈・反応・思考。"
      },
      "action_text": {
        "source_field": "memo_action",
        "meaning": "実世界の出来事。実際に起きたこと・したこと。"
      },
      "emotions": {
        "source_field": "emotion_details",
        "fallback_fields": [
          "emotions"
        ],
        "meaning": "ユーザーが選んだ状態の前提。"
      },
      "emotion_strength_summary": {
        "source_field": "emotion_details",
        "meaning": "状態の重さ。原因断定には使わない。"
      },
      "categories": {
        "source_field": "category",
        "meaning": "話題の方向。原因ではない。"
      },
      "selected_at": {
        "source_field": "created_at",
        "meaning": "今回入力の時点情報。時間推移判断には使わない。"
      },
      "source_record_id": {
        "source_field": "id",
        "meaning": "現在入力の保存レコードID。public contract renameには使わない。"
      }
    },
    "field_meanings": {
      "memo": "自己世界の出来事。内側で起きた解釈・反応・思考。",
      "memo_action": "実世界の出来事。実際に起きたこと・したこと。",
      "emotion_details": "ユーザーが選んだ状態の前提。",
      "emotion_strength": "状態の重さ。原因断定には使わない。",
      "category": "話題の方向。原因ではない。",
      "created_at": "今回入力の時点情報。時間推移判断は別領域。"
    },
    "source_priority": [
      "current_input_explicit_fields",
      "current_input_direct_relations",
      "connected_user_facts",
      "dictionary_candidates",
      "general_knowledge_not_primary"
    ]
  },
  "global_policies": {
    "emotion_policy": {
      "selected_emotion_is_state_premise": true,
      "multiple_emotions_read_as_center_and_surrounding": true,
      "emotion_nesting_allowed": true,
      "emotion_strength_affects_state_weight_only": true,
      "emotion_strength_must_not_create_cause": true,
      "self_insight_is_not_ordinary_emotion": true
    },
    "category_policy": {
      "category_is_topic_direction_not_cause": true,
      "multiple_categories_default_relation": "category_parallel",
      "category_overlap_requires_textual_evidence": true
    },
    "thought_action_policy": {
      "memo_is_self_world_event": true,
      "memo_action_is_real_world_event": true,
      "explicit_discrepancy_should_be_observed": true,
      "surface_order_default": "real_world_fact_to_inner_state_to_human_accompaniment"
    },
    "state_text_gap_policy": {
      "gap_words": [
        "大丈夫",
        "平気",
        "なんでもない",
        "大したことない",
        "大丈夫なはず",
        "まあいいか"
      ],
      "default_surface_strength": "soft",
      "strong_surface_requires": [
        "emotion_strength_strong",
        "clear_gap_word",
        "supporting_memo_or_action_evidence"
      ],
      "strong_surface_must_not_be_low_grounding": true
    },
    "low_information_policy": {
      "short_text_is_not_always_low_information": true,
      "must_state_known_scope": true,
      "must_not_fill_unknown_event": true,
      "prompt_relation": "user_agency_prompt"
    },
    "user_agency_prompt_policy": {
      "preferred_verbs": [
        "残してください",
        "残しても大丈夫です",
        "残せるところだけ残してください"
      ],
      "avoid_verbs": [
        "教えてください",
        "話してください",
        "相談してください",
        "説明してください"
      ],
      "must_preserve_user_agency": true
    },
    "surface_policy": {
      "dictionary_is_not_completed_reply_template": true,
      "composer_owns_final_order": true,
      "surface_realizer_owns_final_japanese": true,
      "must_not_return_entry_text_directly": true
    }
  },
  "relations": [
    {
      "relation_id": "desire_stagnation",
      "definition": "変えたい・進みたい願望と、変化できない現実の停滞を候補として読む関係。",
      "evidence_requirements": [
        "願望語と停止語が同じ入力束内にある",
        "原因は本文根拠がある時だけ扱う"
      ],
      "allowed_inference": [
        "願望と現状の差がある",
        "変化の止まりが負荷になっている可能性を弱く扱う"
      ],
      "forbidden_inference": [
        "環境や人間関係が原因と決める",
        "継続期間を低根拠で足す"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "load_accumulation",
      "definition": "負荷が一回性ではなく蓄積している可能性を候補として読む関係。",
      "evidence_requirements": [
        "疲労・消耗・反復・継続語、または過去事実との明示接続がある"
      ],
      "allowed_inference": [
        "負荷が残っている",
        "反復根拠がある場合のみ蓄積として弱く扱う"
      ],
      "forbidden_inference": [
        "根拠なしに長く続いていると断定する",
        "疲れやすい性格にする"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "action_blocked",
      "definition": "行動したいが動けない、または動く条件が整っていない状態を候補として読む関係。",
      "evidence_requirements": [
        "行動願望と停止・不能語が同じ入力束内にある"
      ],
      "allowed_inference": [
        "行動と実行の間に距離がある",
        "停止条件がある可能性を扱う"
      ],
      "forbidden_inference": [
        "怠惰・弱さとして人格化する",
        "努力不足と決める"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "pressure_gap",
      "definition": "現状と期待・願望・責任の差が圧力として残っている可能性を候補として読む関係。",
      "evidence_requirements": [
        "期待・責任・現状差を示す語が入力束内にある"
      ],
      "allowed_inference": [
        "差分が圧力に近い状態として残っている可能性"
      ],
      "forbidden_inference": [
        "誰からの圧力かを勝手に足す",
        "社会的評価を補完する"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "repetition",
      "definition": "同じ思考・状況・試行が繰り返されている可能性を候補として読む関係。",
      "evidence_requirements": [
        "繰り返し語、継続語、または現在入力に接続できる過去ユーザー事実がある"
      ],
      "allowed_inference": [
        "同じ構造が繰り返されている可能性",
        "過去事実がある場合だけ継続として扱う"
      ],
      "forbidden_inference": [
        "過去事実なしに続いていると強く言う",
        "反応パターンを人格化する"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "priority_pressure",
      "definition": "対象が大きく扱われ続けることで負荷が出ている可能性を候補として読む関係。",
      "evidence_requirements": [
        "対象語と負荷語が現在入力で直接つながる"
      ],
      "allowed_inference": [
        "その対象が入力内で大きく扱われている可能性"
      ],
      "forbidden_inference": [
        "重要視していると断定する",
        "執着などの心理語へ寄せる"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "low_information_weight",
      "definition": "詳細は少ないが、重さや限界感だけは入力束から見えている状態。",
      "evidence_requirements": [
        "短文でも感情・強度・カテゴリ・入力語から状態の重さが見える",
        "出来事・対象・原因は未確定として残す"
      ],
      "allowed_inference": [
        "見えている状態の重さだけを扱う",
        "未知の出来事を明示してユーザー主導で促す"
      ],
      "forbidden_inference": [
        "職場・人間関係・過去の傷を補完する",
        "質問だけで終わる"
      ],
      "surface_policy": {
        "default_strength": "medium",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "state_text_gap",
      "definition": "選択された感情状態と、本文に置いた言葉が乖離している状態。",
      "evidence_requirements": [
        "感情選択と本文の語が同じ入力束内にある",
        "強表現は感情strongと補助根拠がある時だけ使う"
      ],
      "allowed_inference": [
        "感情状態と本文の間に差がある",
        "その言葉を置いていること自体を観測する"
      ],
      "forbidden_inference": [
        "本当の感情を決め打ちする",
        "嘘をついていると扱う",
        "自分に言い聞かせていると低根拠で断定する"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "emotion_nesting",
      "definition": "強い感情の箱の中に、別の感情が混ざっている状態。",
      "evidence_requirements": [
        "複数感情が同じ入力に選択されている",
        "中心と周辺は強度と順序から弱く扱う"
      ],
      "allowed_inference": [
        "中心感情と周辺感情が同じ入力内にある",
        "感情の混ざりを弱く表現する"
      ],
      "forbidden_inference": [
        "本当の感情を断定する",
        "防衛などの心理診断語にする",
        "感情を割合で表示する"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "thought_action_discrepancy",
      "definition": "実世界の行動と、自己世界の思考・感情がズレている状態。",
      "evidence_requirements": [
        "memo_actionとmemoの両方に明示された差がある"
      ],
      "allowed_inference": [
        "外側の行動と内側の状態の差を観測する",
        "情報が明確なら踏み込んだ状態言語化を行う"
      ],
      "forbidden_inference": [
        "ズレがない入力にズレを作る",
        "我慢する性格などに人格化する"
      ],
      "surface_policy": {
        "default_strength": "strong_when_high_grounding",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "category_parallel",
      "definition": "複数カテゴリを、本文根拠なしでは並列の話題方向として受け取る関係。",
      "evidence_requirements": [
        "複数カテゴリがある",
        "本文内にカテゴリ間の因果根拠がない"
      ],
      "allowed_inference": [
        "複数カテゴリの両方に関係する話題方向として扱う"
      ],
      "forbidden_inference": [
        "片方を原因にする",
        "カテゴリだけで影響関係を作る"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "category_overlap",
      "definition": "本文根拠により、複数カテゴリが重なっていると読める状態。",
      "evidence_requirements": [
        "複数カテゴリがある",
        "memoまたはmemo_actionにカテゴリ同士をつなぐ具体根拠がある"
      ],
      "allowed_inference": [
        "仕事の中の人間関係、仕事の負荷が健康不安に出るなどを根拠ありで読む"
      ],
      "forbidden_inference": [
        "複数カテゴリだけで因果関係を作る"
      ],
      "surface_policy": {
        "default_strength": "medium",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "self_insight_discovery",
      "definition": "自己理解が、感情ではなく気づき・発見として出ている状態。",
      "evidence_requirements": [
        "自己理解が選択されている",
        "memo内に気づき・選び方・反応・構造への記述がある"
      ],
      "allowed_inference": [
        "気づきの記録として扱う",
        "自分の選び方や反応に気づいた状態として扱う"
      ],
      "forbidden_inference": [
        "普通の悲しみ・不安として扱う",
        "性格診断にする",
        "あなたはこういう人と断定する"
      ],
      "surface_policy": {
        "default_strength": "medium",
        "must_use_humility_marker": true,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "user_agency_prompt",
      "definition": "追加情報を促すが、主導権をユーザーに残す関係。",
      "evidence_requirements": [
        "低情報または未知スロットがある",
        "追加情報が必須ではない形で促す"
      ],
      "allowed_inference": [
        "今のペースを尊重した追加入力の促し",
        "残せるところだけ残す方向の促し"
      ],
      "forbidden_inference": [
        "説明責任を押しつける",
        "相談してくださいと誘導する",
        "教えてください中心にする"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": false,
        "must_not_return_directly": true
      }
    },
    {
      "relation_id": "unexpressed_output_stop",
      "definition": "出したい出力があるが、言葉化または相手へ渡る直前で止まった状態を候補として読む関係。",
      "evidence_requirements": [
        "memo または memo_action に、言えなかった・伝えられなかった・飲み込んだ等の明示語がある",
        "出したい内容・相手・場のいずれかが入力束に見えている場合だけ踏み込む",
        "明示語だけの場合は、未出力の事実候補に留める"
      ],
      "allowed_inference": [
        "出したいものが外へ出る前で止まった可能性",
        "未出力として残っている可能性",
        "入力束に根拠がある場合の内外のズレ"
      ],
      "forbidden_inference": [
        "弱さ・臆病さ・コミュニケーション能力不足への人格化",
        "本当は何を言いたかったかの補完",
        "相手が怖かった・相手が悪い等の原因決め打ち",
        "言うべきだったという行動指示"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true,
        "notes": "未出力の可能性を扱い、内容や原因は補完しない。"
      }
    },
    {
      "relation_id": "self_shape_alignment",
      "definition": "自分の形や出力を、場・相手・状況に合わせて変形して出した状態を候補として読む関係。",
      "evidence_requirements": [
        "memo または memo_action に、合わせた・合わせてしまった・空気を読んだ・場に合わせた等の明示語がある",
        "場・相手・状況の根拠が入力束にある場合だけ対象を扱う",
        "明示語だけの場合は、自分の形を寄せた可能性に留める"
      ],
      "allowed_inference": [
        "自分の出力を場や相手へ寄せた可能性",
        "外側に出した形と内側の形に距離がある可能性",
        "合わせた行動が履歴として残っている可能性"
      ],
      "forbidden_inference": [
        "八方美人・迎合的・主体性がない等の人格化",
        "相手や場が支配的だったと断定",
        "合わせることを良い/悪いと評価",
        "本音の内容を補完"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true,
        "notes": "合わせた行動を、自己形状の一時変換として扱う。評価語にしない。"
      }
    },
    {
      "relation_id": "action_conversion_history",
      "definition": "したい出力は選択肢の上位に残っているが、実際には別の行動へ変換し、その変換後の行動が履歴として格納された状態を候補として読む関係。",
      "evidence_requirements": [
        "memo または memo_action に、我慢した・耐えた・抑えた・言わなかった等の明示語がある",
        "したい出力と実際の行動の両方が見える場合だけ差分を扱う",
        "片方だけの場合は、行動変換があった可能性に留める"
      ],
      "allowed_inference": [
        "したい出力とは別の行動を選んだ可能性",
        "変換後の行動がユーザーの履歴として残っている可能性",
        "入力根拠がある場合の納得・未完了・疲労などの閉じ方候補"
      ],
      "forbidden_inference": [
        "本当は何をしたかったかを補完",
        "相手のため・優しさ・自己犠牲と決め打ち",
        "我慢できる人・我慢しがちな人等の人格傾向化",
        "納得できていない、決定権を失った等の閉じ方を根拠なしに確定"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true,
        "notes": "我慢を単なる耐性ではなく、行動変換後の履歴として扱う。"
      }
    },
    {
      "relation_id": "conversion_history_closure",
      "definition": "行動変換後の履歴が、納得・未完了・自己否定・関係維持・未来目的・疲労などのどの形で扱われているかを、入力根拠に応じて弱く読む関係。",
      "evidence_requirements": [
        "action_conversion_history の根拠がある",
        "納得・引っかかり・またやった・仕方ない・相手や場・将来・疲れ等の閉じ方の跡が入力束にある",
        "閉じ方は複数同時に成立し得るため、単一判定にしない"
      ],
      "allowed_inference": [
        "納得として閉じている可能性",
        "未完了で残っている可能性",
        "自己評価へ落ちている可能性",
        "関係維持や未来目的として意味づけている可能性",
        "意味は通っていても変換疲労が残る可能性"
      ],
      "forbidden_inference": [
        "閉じ方を一つに決める",
        "納得/未完了/自己否定などを根拠なしに断定",
        "我慢の正しさを評価",
        "ユーザーの意味づけをAI側で完了させる"
      ],
      "surface_policy": {
        "default_strength": "soft",
        "must_use_humility_marker": true,
        "must_not_return_directly": true,
        "notes": "閉じ方は候補として扱う。ユーザーの意味づけの決定権を奪わない。"
      }
    },
    {
      "relation_id": "unformed_self_insight",
      "definition": "内側で反応や疑問は起きているが、まだ整合性のある言葉や自己理解の形へ並びきっていない状態を候補として読む関係。",
      "evidence_requirements": [
