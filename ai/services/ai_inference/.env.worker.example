# ASTOR worker production example
# Copy into the worker service environment. Do not put service_role secrets in RN.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
ASTOR_JOBS_TABLE=astor_jobs

# API service should enqueue heavy work instead of doing it locally.
ASTOR_WORKER_QUEUE_ENABLED=true
ASTOR_WORKER_QUEUE_FALLBACK_LOCAL=false
COCOLON_HIGH_LOAD_MODE=true

# Worker identity and scope.
# Profile values: all, core, analysis, inspect, ranking, summary, notification
ASTOR_WORKER_ID=astor-worker-core-1
ASTOR_WORKER_PROFILE=core

# If you use ASTOR_WORKER_JOB_TYPES manually and want a specialized worker,
# set ASTOR_WORKER_INCLUDE_REQUIRED_JOB_TYPES=false.
# ASTOR_WORKER_JOB_TYPES=myprofile_latest_refresh_v1,snapshot_generate_v1
ASTOR_WORKER_INCLUDE_REQUIRED_JOB_TYPES=true


# FCM dedicated queue.
# API / cron enqueue send_fcm_push_v1; notification workers perform token lookup and FCM send.
FCM_PUSH_QUEUE_ENABLED=true
FCM_PUSH_QUEUE_FALLBACK_DIRECT=false
FCM_PUSH_QUEUE_CHUNK_SIZE=200
FCM_PUSH_QUEUE_MAX_ATTEMPTS=5

# Notification worker example:
# ASTOR_WORKER_ID=astor-worker-notification-1
# ASTOR_WORKER_PROFILE=notification

# FCM credentials are required on notification workers when FCM_PUSH_ENABLED=true.
FCM_PUSH_ENABLED=true
# FCM_SERVICE_ACCOUNT_FILE=/etc/secrets/firebase_service_account.json
# or FCM_SERVICE_ACCOUNT_JSON_BASE64=...
# or FCM_SERVER_KEY=...  # legacy fallback only

# Polling and maintenance.
ASTOR_WORKER_POLL_INTERVAL_SECONDS=0.5
ASTOR_WORKER_MAINTENANCE_INTERVAL_SECONDS=60
ASTOR_WORKER_QUEUE_STATS_LOG_ENABLED=true

# Stale running recovery. Increase if one job can legitimately run longer.
ASTOR_WORKER_STALE_RUNNING_SECONDS=900
ASTOR_WORKER_STALE_REQUEUE_LIMIT=25

# Debounce / queue behavior.
ASTOR_SNAPSHOT_ENQUEUE_ENABLED=true
ASTOR_SELF_STRUCTURE_DEBOUNCE_SECONDS=300
ASTOR_SNAPSHOT_DEBOUNCE_SECONDS=300

# Status script thresholds.
ASTOR_WORKER_READY_THRESHOLD=50
ASTOR_WORKER_STALE_THRESHOLD=1
ASTOR_QUEUE_STATS_LIMIT=5000

ASTOR_WORKER_LOG_LEVEL=INFO
