# services/ai_inference/.env.subscription.backend.example
# ------------------------------------------------------------
# Cocolon backend subscription env sample
# - Store verification / webhook secrets stay here.
# - Sales labels, legal URLs, plan visibility and SKU aliases are runtime-managed
#   by /subscription/bootstrap tables after the RN shell is released.
# ------------------------------------------------------------

# Public API base URL used to derive webhook targets in the release-check report
COCOLON_IAP_PUBLIC_API_BASE_URL=https://api.example.com

# Safety
COCOLON_IAP_ALLOW_UNVERIFIED=false
COCOLON_SUBSCRIPTION_SALES_ENABLED=true
# Optional platform-specific kill switches
# COCOLON_SUBSCRIPTION_IOS_SALES_ENABLED=true
# COCOLON_SUBSCRIPTION_ANDROID_SALES_ENABLED=true
# Optional minimum app versions for paid sales
# COCOLON_SUBSCRIPTION_IOS_MIN_APP_VERSION=1.0.0
# COCOLON_SUBSCRIPTION_ANDROID_MIN_APP_VERSION=1.0.0

# Product IDs (comma separated when you have multiple SKUs per plan)
COCOLON_IAP_IOS_PLUS_PRODUCT_IDS=cocolon_plus_monthly
COCOLON_IAP_IOS_PREMIUM_PRODUCT_IDS=cocolon_premium_monthly
COCOLON_IAP_ANDROID_PLUS_PRODUCT_IDS=emlis
COCOLON_IAP_ANDROID_PREMIUM_PRODUCT_IDS=emlis
COCOLON_IAP_ANDROID_PLUS_BASE_PLAN_IDS=plus
COCOLON_IAP_ANDROID_PREMIUM_BASE_PLAN_IDS=premium

# Apple App Store Server API
# Optional: if you want Phase 4 live App Store Connect catalog checks with a separate key,
# provide the ASC-prefixed values below. If omitted, Phase 4 falls back to the Apple server key.
# COCOLON_IAP_ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
# COCOLON_IAP_ASC_KEY_ID=ABC123DEFG
# COCOLON_IAP_ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# COCOLON_IAP_ASC_PRIVATE_KEY_FILE=/etc/secrets/appstoreconnect/AuthKey_ASC.p8
COCOLON_IAP_APPLE_ISSUER_ID=00000000-0000-0000-0000-000000000000
COCOLON_IAP_APPLE_KEY_ID=ABC123DEFG
COCOLON_IAP_APPLE_BUNDLE_ID=com.example.cocolon
# Use either inline private key or a mounted file path
# COCOLON_IAP_APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# COCOLON_IAP_APPLE_PRIVATE_KEY_FILE=/etc/secrets/appstoreconnect/AuthKey_ABC123DEFG.p8
COCOLON_IAP_APPLE_TRY_SANDBOX=true

# Google Play Developer API
COCOLON_IAP_ANDROID_PACKAGE_NAME=com.example.cocolon
# Use one of the credential styles below
# COCOLON_IAP_GOOGLE_SERVICE_ACCOUNT_JSON={...full json...}
# COCOLON_IAP_GOOGLE_SERVICE_ACCOUNT_JSON_FILE=/etc/secrets/google-play-service-account.json
# COCOLON_IAP_GOOGLE_CLIENT_EMAIL=play-verifier@example.iam.gserviceaccount.com
# COCOLON_IAP_GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
COCOLON_IAP_GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token

# Runtime legal / support links (runtime table is preferred; env acts as fallback / release-check expectation)
COCOLON_SUBSCRIPTION_TERMS_URL=https://example.com/terms
COCOLON_SUBSCRIPTION_PRIVACY_URL=https://example.com/privacy
COCOLON_SUBSCRIPTION_SUPPORT_URL=https://example.com/support
# Optional override for review / support copy
# COCOLON_SUBSCRIPTION_REVIEW_NOTICE=現在、Plusのみ販売中です。

# Optional webhook hardening
COCOLON_IAP_GOOGLE_WEBHOOK_BEARER=replace-with-random-secret

# Optional admin bearer for release-check endpoint and runtime ops
COCOLON_SUBSCRIPTION_ADMIN_BEARER=replace-with-random-secret
